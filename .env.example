APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Backup email notification (sends backup completion notifications)
MAIL_BACKUP_EMAIL=aaronclydeccervantes@gmail.com
SEND_BACKUP_EMAIL=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# MySQL attendance source configuration
# Table name containing attendance records
MYSQL_ATTENDANCE_TABLE=attendance_source
# Column names in the MySQL table
MYSQL_ATTENDANCE_NAME_COLUMN=full_name
MYSQL_ATTENDANCE_COLUMN=attendance
MYSQL_ATTENDANCE_DATE_COLUMN=date_time
MYSQL_ATTENDANCE_LOCATION_COLUMN=location
MYSQL_ATTENDANCE_SHIFT_COLUMN=shift_type

# AI Provider Configuration (groq | openrouter)
AI_PROVIDER=groq
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
